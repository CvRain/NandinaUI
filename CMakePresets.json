{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 0,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-msvc-base",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "VCPKG_HOST_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "windows-clang-base",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-static",
        "VCPKG_HOST_TRIPLET": "x64-mingw-static"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux",
        "VCPKG_HOST_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "default",
      "displayName": "Default (Debug)",
      "description": "向后兼容的默认配置，输出至 build/，clangd 默认指向此目录。VCPKG_MANIFEST_INSTALL=OFF：在 GitHub TLS 受限的沙箱环境中跳过 vcpkg 安装，回退到系统已安装的包。在网络正常的机器上请使用对应的平台预设。",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NANDINA_BUILD_TESTS": "ON",
        "VCPKG_MANIFEST_INSTALL": "OFF"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug 构建，启用全部警告与单元测试，输出至 build/debug",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NANDINA_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "优化发布构建，禁用测试，输出至 build/release",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NANDINA_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "debug-asan",
      "displayName": "Debug (AddressSanitizer)",
      "description": "Debug 构建，启用 AddressSanitizer + UndefinedBehaviorSanitizer（仅 Clang/GCC），输出至 build/debug-asan",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/debug-asan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NANDINA_BUILD_TESTS": "ON",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "description": "Windows x64 MSVC Debug 构建，使用 vcpkg x64-windows-static triplet，启用测试，输出至 build/windows-msvc-debug",
      "inherits": "windows-msvc-base",
      "binaryDir": "${sourceDir}/build/windows-msvc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NANDINA_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Windows MSVC Release",
      "description": "Windows x64 MSVC Release 构建，使用 vcpkg x64-windows-static triplet，禁用测试，输出至 build/windows-msvc-release",
      "inherits": "windows-msvc-base",
      "binaryDir": "${sourceDir}/build/windows-msvc-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NANDINA_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "windows-clang-debug",
      "displayName": "Windows Clang Debug",
      "description": "Windows x64 Clang Debug 构建，使用 vcpkg x64-mingw-static triplet，启用测试，输出至 build/windows-clang-debug",
      "inherits": "windows-clang-base",
      "binaryDir": "${sourceDir}/build/windows-clang-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NANDINA_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-clang-release",
      "displayName": "Windows Clang Release",
      "description": "Windows x64 Clang Release 构建，使用 vcpkg x64-mingw-static triplet，禁用测试，输出至 build/windows-clang-release",
      "inherits": "windows-clang-base",
      "binaryDir": "${sourceDir}/build/windows-clang-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NANDINA_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "linux-clang-debug",
      "displayName": "Linux Clang Debug",
      "description": "Linux x64 Clang Debug 构建，使用 vcpkg x64-linux triplet，启用测试，输出至 build/linux-clang-debug",
      "inherits": "linux-base",
      "binaryDir": "${sourceDir}/build/linux-clang-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NANDINA_BUILD_TESTS": "ON",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "linux-clang-release",
      "displayName": "Linux Clang Release",
      "description": "Linux x64 Clang Release 构建，使用 vcpkg x64-linux triplet，禁用测试，输出至 build/linux-clang-release",
      "inherits": "linux-base",
      "binaryDir": "${sourceDir}/build/linux-clang-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NANDINA_BUILD_TESTS": "OFF",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "linux-gcc-debug",
      "displayName": "Linux GCC Debug",
      "description": "Linux x64 GCC Debug 构建，使用 vcpkg x64-linux triplet，启用测试，输出至 build/linux-gcc-debug。⚠ 注意：由于项目使用了 C++20 Modules 新特性，GCC 对模块的支持尚不完善，使用此预设构建可能会出现编译失败。推荐优先使用 linux-clang-debug。",
      "inherits": "linux-base",
      "binaryDir": "${sourceDir}/build/linux-gcc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NANDINA_BUILD_TESTS": "ON",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "linux-gcc-release",
      "displayName": "Linux GCC Release",
      "description": "Linux x64 GCC Release 构建，使用 vcpkg x64-linux triplet，禁用测试，输出至 build/linux-gcc-release。⚠ 注意：由于项目使用了 C++20 Modules 新特性，GCC 对模块的支持尚不完善，使用此预设构建可能会出现编译失败。推荐优先使用 linux-clang-release。",
      "inherits": "linux-base",
      "binaryDir": "${sourceDir}/build/linux-gcc-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NANDINA_BUILD_TESTS": "OFF",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "displayName": "Build (default)",
      "configurePreset": "default"
    },
    {
      "name": "debug",
      "displayName": "Build (debug)",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "displayName": "Build (release)",
      "configurePreset": "release"
    },
    {
      "name": "debug-asan",
      "displayName": "Build (debug-asan)",
      "configurePreset": "debug-asan"
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Build (windows-msvc-debug)",
      "configurePreset": "windows-msvc-debug"
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Build (windows-msvc-release)",
      "configurePreset": "windows-msvc-release"
    },
    {
      "name": "windows-clang-debug",
      "displayName": "Build (windows-clang-debug)",
      "configurePreset": "windows-clang-debug"
    },
    {
      "name": "windows-clang-release",
      "displayName": "Build (windows-clang-release)",
      "configurePreset": "windows-clang-release"
    },
    {
      "name": "linux-clang-debug",
      "displayName": "Build (linux-clang-debug)",
      "configurePreset": "linux-clang-debug"
    },
    {
      "name": "linux-clang-release",
      "displayName": "Build (linux-clang-release)",
      "configurePreset": "linux-clang-release"
    },
    {
      "name": "linux-gcc-debug",
      "displayName": "Build (linux-gcc-debug)",
      "configurePreset": "linux-gcc-debug"
    },
    {
      "name": "linux-gcc-release",
      "displayName": "Build (linux-gcc-release)",
      "configurePreset": "linux-gcc-release"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "displayName": "Test (default)",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug",
      "displayName": "Test (debug)",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      }
    },
    {
      "name": "debug-asan",
      "displayName": "Test (debug-asan)",
      "configurePreset": "debug-asan",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      }
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Test (windows-msvc-debug)",
      "configurePreset": "windows-msvc-debug",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      }
    },
    {
      "name": "windows-clang-debug",
      "displayName": "Test (windows-clang-debug)",
      "configurePreset": "windows-clang-debug",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      }
    },
    {
      "name": "linux-clang-debug",
      "displayName": "Test (linux-clang-debug)",
      "configurePreset": "linux-clang-debug",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      }
    },
    {
      "name": "linux-gcc-debug",
      "displayName": "Test (linux-gcc-debug)",
      "configurePreset": "linux-gcc-debug",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      }
    }
  ]
}