{
  "name": "nandina-ui",
  "version": "0.1.0",
  "description": "NandinaUI — C++26 UI runtime + design-system-driven widget library",
  "dependencies": [
    {
      "name": "dbus",
      "default-features": false,
      "platform": "linux"
    },
    "freetype",
    "gtest",
    "harfbuzz",
    {
      "name": "sdl3",
      "platform": "linux",
      "features": [
        "dbus"
      ]
    },
    {
      "name": "sdl3",
      "platform": "!linux"
    },
    "thorvg",
    "yoga",
    "spdlog"
  ]
}
