# clangd 配置 — NandinaUI (C++26 + C++20 Modules)
#
# 编译数据库指向 CMake linux-clang-debug 预设的输出目录。
# 使用其他预设时请相应修改 CompilationDatabase 路径。
#
# ⚠ clangd 对 C++20 Modules 的支持需要：
#   1. CMake 4.x 已配置并生成 compile_commands.json
#   2. 项目至少构建过一次（生成 @*.modmap 响应文件与 .pcm 模块文件）
#   3. 当模块依赖关系变化时需重新构建以更新 .pcm 文件
#
# 首次使用：
#   cmake --preset linux-clang-debug
#   cmake --build --preset linux-clang-debug -j$(nproc)

CompileFlags:
    CompilationDatabase: build/linux-clang-debug

    # CMake 在 linux-gcc-* 预设下会向 compile_commands.json 写入 GCC 专有
    # 模块扫描参数（-fmodules-ts, -fmodule-mapper=* 等），clangd 使用 Clang
    # 驱动无法识别这些参数，在此提前移除并替换为 Clang 兼容的参数。
    # 当使用 Clang 预设时 compile_commands 不含这些 GCC 标志，Remove 无副作用。
    Remove:
        - -fmodules-ts
        - -fmodule-mapper=*
        - -fdeps-format=*
        - -fdeps-file=*
    Add:
        - -std=c++26
        - -fmodules
        - -Wall
        - -Wextra
        - -Wpedantic

Diagnostics:
    ClangTidy:
        Add:
            - bugprone-*
            - modernize-*
            - performance-*
            - readability-*
        Remove:
            - modernize-use-trailing-return-type
    UnusedIncludes: Strict

Index:
    Background: Build

InlayHints:
    Enabled: Yes
    ParameterNames: Yes
    DeducedTypes: Yes
    BlockEnd: No
